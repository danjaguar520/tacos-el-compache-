# ============================================================
# Tacos El Compache de Ah Mun — Variables de entorno
# Copia este archivo a .env.local y rellena tus llaves.
# La app funciona en MODO DEMO si dejas los placeholders (__...__):
#   - Menú: usa el catálogo estático de src/data/menu.ts
#   - Pago: se simula y va directo a /checkout/success
# ============================================================

# --- URL pública del sitio (para back_urls y webhook de Mercado Pago) ---
# LOCAL:      http://localhost:3000
# PRODUCCIÓN: https://tu-proyecto.vercel.app  (o tu dominio personalizado)
# ⚠️  Debe ser la URL real de Vercel para que los pagos redirijan correctamente.
NEXT_PUBLIC_SITE_URL=__url_publica_del_sitio__

# --- Supabase ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=__pega_aqui__
NEXT_PUBLIC_SUPABASE_ANON_KEY=__pega_aqui__
# ¡SECRETO! Solo en el servidor. Nunca lo expongas en el cliente.
SUPABASE_SERVICE_ROLE_KEY=__pega_aqui__

# --- Mercado Pago ---
# Tus credenciales (sandbox o producción): https://www.mercadopago.com.mx/developers
MP_ACCESS_TOKEN=__pega_aqui__
# NEXT_PUBLIC_MP_PUBLIC_KEY no es usada por el código actual (Checkout Pro es server-side).
# Puedes omitirla en Vercel.

# --- Panel de administración (/admin/pedidos) ---
# Si lo dejas vacío, el panel queda ABIERTO (solo para desarrollo).
# Define una contraseña para exigir inicio de sesión.
ADMIN_PASSWORD=__define_una_contraseña__

# --- Lok'al Business Factory (/factory) ---
# Si lo dejas vacío, el Factory queda ABIERTO (solo para desarrollo).
# Define una contraseña para exigir inicio de sesión — el Factory invoca a
# Claude AI y genera costos reales por cada uso, así que conviene protegerlo
# en cualquier entorno expuesto públicamente.
FACTORY_ACCESS_PASSWORD=__define_una_contraseña_para_el_factory__
